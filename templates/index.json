{
  "sections": {
    "image_banner": {
      "type": "image-banner",
      "blocks": {
        "heading": {
          "type": "heading",
          "settings": {
            "heading": "Aurevia Market",
            "heading_size": "h0"
          }
        },
        "caption": {
          "type": "text",
          "settings": {
            "text": "Productos seleccionados con criterio. Calidad, transparencia y servicio cercano.",
            "text_style": "body"
          }
        }
      },
      "block_order": [
        "heading",
        "caption"
      ],
      "settings": {
        "image": "shopify://shop_images/ChatGPT_Image_21_abr_2026_20_00_06.png",
        "image_overlay_opacity": 60,
        "image_height": "large",
        "image_behavior": "ambient",
        "desktop_content_position": "middle-center",
        "desktop_content_alignment": "center",
        "show_text_box": false,
        "color_scheme": "scheme-premium-gold",
        "stack_images_on_mobile": false,
        "mobile_content_alignment": "center",
        "show_text_below": false
      }
    },
    "trust_strip": {
      "type": "feature-icons",
      "blocks": {
        "ts1": {
          "type": "feature",
          "settings": {
            "icon": "truck",
            "title": "Envío 24–72h",
            "text": "<p>Despacho rápido con seguimiento en todo el país.</p>"
          }
        },
        "ts2": {
          "type": "feature",
          "settings": {
            "icon": "lock",
            "title": "Pago seguro",
            "text": "<p>Tarjeta, transferencia y pasarelas certificadas.</p>"
          }
        },
        "ts3": {
          "type": "feature",
          "settings": {
            "icon": "refresh",
            "title": "Garantía 30 días",
            "text": "<p>Devolución sencilla si no quedas satisfecho.</p>"
          }
        },
        "ts4": {
          "type": "feature",
          "settings": {
            "icon": "chat",
            "title": "Atención humana",
            "text": "<p>Soporte directo por WhatsApp y correo.</p>"
          }
        }
      },
      "block_order": ["ts1", "ts2", "ts3", "ts4"],
      "settings": {
        "caption": "Nuestra promesa",
        "title": "Compra con confianza",
        "icon_style": "soft",
        "columns_desktop": 4,
        "columns_mobile": "2",
        "color_scheme": "scheme-1",
        "padding_top": 72,
        "padding_bottom": 36
      }
    },
    "catalog_grid": {
      "type": "catalog-grid",
      "settings": {
        "eyebrow": "Selección Aurevia",
        "title": "Catálogo",
        "subheading": "Una selección curada de productos pensados para personas exigentes.",
        "collection": "all",
        "products_to_show": 8,
        "columns_desktop": 3,
        "columns_mobile": "2",
        "show_vendor": false,
        "cta_label": "Ver detalles",
        "show_view_all": true,
        "view_all_label": "Ver todo el catálogo",
        "color_scheme": "scheme-1",
        "padding_top": 36,
        "padding_bottom": 64
      }
    },
    "brand_story": {
      "type": "rich-text",
      "blocks": {
        "caption": {
          "type": "caption",
          "settings": {
            "caption": "Filosofía Aurevia",
            "text_style": "uppercase",
            "text_size": "medium"
          }
        },
        "heading": {
          "type": "heading",
          "settings": {
            "heading": "Productos elegidos con criterio",
            "heading_size": "h1"
          }
        },
        "text": {
          "type": "text",
          "settings": {
            "text": "<p>Curamos cada producto pensando en personas exigentes que valoran calidad, transparencia y un servicio cercano. Sin presión, sin descuentos agresivos: solo cosas que vale la pena tener.</p>"
          }
        },
        "button": {
          "type": "button",
          "settings": {
            "button_label": "Ver el catálogo",
            "button_link": "shopify://collections/all",
            "button_style_secondary": false
          }
        }
      },
      "block_order": ["caption", "heading", "text", "button"],
      "settings": {
        "desktop_content_position": "center",
        "content_alignment": "center",
        "color_scheme": "scheme-premium-gold",
        "full_width": true,
        "padding_top": 80,
        "padding_bottom": 80
      }
    },
    "home_faq": {
      "type": "collapsible-content",
      "blocks": {
        "hf1": {
          "type": "collapsible_row",
          "settings": {
            "heading": "¿Cuánto tarda el envío?",
            "row_content": "<p>Procesamos los pedidos en 24 horas hábiles. La entrega suele tomar entre 2 y 5 días hábiles dentro del país, con seguimiento en tiempo real.</p>"
          }
        },
        "hf2": {
          "type": "collapsible_row",
          "settings": {
            "heading": "¿Puedo devolver un producto?",
            "row_content": "<p>Sí. Tienes 30 días desde la recepción para solicitar la devolución, siempre que el producto esté sin uso y en su empaque original.</p>"
          }
        },
        "hf3": {
          "type": "collapsible_row",
          "settings": {
            "heading": "¿Cómo puedo contactarlos?",
            "row_content": "<p>Estamos disponibles por WhatsApp y correo electrónico desde la página de contacto. Te respondemos en horario hábil.</p>"
          }
        }
      },
      "block_order": ["hf1", "hf2", "hf3"],
      "settings": {
        "heading": "Preguntas frecuentes",
        "heading_size": "h2",
        "heading_alignment": "center",
        "layout": "none",
        "color_scheme": "scheme-1",
        "container_color_scheme": "scheme-2",
        "open_first_collapsible_row": false,
        "padding_top": 56,
        "padding_bottom": 80
      }
    }
  },
  "order": [
    "image_banner",
    "trust_strip",
    "catalog_grid",
    "brand_story",
    "home_faq"
  ]
}

    "benefits": {
      "type": "multicolumn",
      "blocks": {
        "b1": {
          "type": "column",
          "settings": {
            "title": "Antioxidante natural",
            "text": "<p>Astaxantina obtenida de microalga <em>Haematococcus pluvialis</em>, una de las moléculas antioxidantes más potentes conocidas.</p>"
          }
        },
        "b2": {
          "type": "column",
          "settings": {
            "title": "Apoyo a piel y vista",
            "text": "<p>Contribuye a proteger la piel del estrés oxidativo y al confort visual diario frente a pantallas y luz intensa.</p>"
          }
        },
        "b3": {
          "type": "column",
          "settings": {
            "title": "Energía y recuperación",
            "text": "<p>Apoya el rendimiento físico y la recuperación muscular tras la actividad deportiva.</p>"
          }
        },
        "b4": {
          "type": "column",
          "settings": {
            "title": "Fórmula limpia",
            "text": "<p>Sin gluten, sin transgénicos y apto para dietas veganas. Cápsula de origen vegetal.</p>"
          }
        }
      },
      "block_order": ["b1", "b2", "b3", "b4"],
      "settings": {
        "title": "Beneficios principales",
        "heading_size": "h2",
        "image_width": "third",
        "image_ratio": "circle",
        "columns_desktop": 4,
        "column_alignment": "center",
        "background_style": "none",

{%- liquid
  assign image_source = section.settings.image
  if image_source == blank and product != blank
    assign image_source = product.featured_media
  endif
-%}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --gold: #d4af37;
    --warm: #ffcf4d;
    --warm-deep: #ff9f1c;
  }

  body {
    background: #07111c;
  }

  .solar-hero {
    background: radial-gradient(circle at top left, #1f3b57 0%, #07111c 48%, #02060a 100%);
    padding: clamp(56px, 8vw, 96px) 20px;
    color: #ffffff;
    overflow: hidden;
    position: relative;
  }

  .solar-hero::before,
  .solar-hero::after {
    content: "";
    position: absolute;
    pointer-events: none;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.35;
  }

  .solar-hero::before {
    top: -120px;
    left: -120px;
    width: 380px;
    height: 380px;
    background: radial-gradient(circle, rgba(255, 207, 77, 0.6), transparent 70%);
  }

  .solar-hero::after {
    bottom: -150px;
    right: -100px;
    width: 360px;
    height: 360px;
    background: radial-gradient(circle, rgba(31, 59, 87, 0.9), transparent 70%);
    opacity: 0.55;
  }

  .solar-hero__content {
    max-width: 1180px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 56px;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .solar-hero__badge {
    display: inline-block;
    background: rgba(255, 205, 83, 0.12);
    color: #ffd46a;
    border: 1px solid rgba(255, 205, 83, 0.4);
    padding: 9px 16px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.04em;
    margin-bottom: 22px;
    backdrop-filter: blur(8px);
  }

  .solar-hero h1 {
    font-size: clamp(34px, 4.6vw, 58px);
    line-height: 1.05;
    margin: 0 0 22px;
    color: #ffffff;
    letter-spacing: -1.2px;
    font-weight: 700;
  }

  .solar-hero__subtitle {
    font-size: clamp(16px, 1.2vw, 18px);
    line-height: 1.65;
    color: #d8e4f0;
    margin: 0 0 28px;
    max-width: 560px;
  }

  .solar-hero__benefits {
    display: grid;
    gap: 11px;
    margin-bottom: 32px;
    color: #f4f8fb;
    font-size: 16px;
  }

  .solar-hero__benefits div {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    line-height: 1.45;
  }

  .solar-hero__benefits .check {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: rgba(255, 207, 77, 0.18);
    color: #ffd46a;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 2px;
  }

  .solar-hero__benefits .check svg {
    width: 12px;
    height: 12px;
    stroke: currentColor;
    fill: none;
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .solar-hero__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: linear-gradient(135deg, #ffcf4d, #ff9f1c);
    color: #111111;
    text-decoration: none;
    font-weight: 800;
    font-size: 16px;
    letter-spacing: 0.02em;
    padding: 16px 34px;
    border-radius: 14px;
    box-shadow: 0 12px 30px rgba(255, 174, 31, 0.35);
    transition: transform 0.25s cubic-bezier(0.2, 0.8, 0.2, 1),
                box-shadow 0.25s ease;
    cursor: pointer;
    border: 0;
  }

  .solar-hero__button:hover {
    transform: translateY(-3px);
    box-shadow: 0 18px 40px rgba(255, 174, 31, 0.5);
  }

  .solar-hero__button svg {
    width: 16px;
    height: 16px;
    stroke: currentColor;
    fill: none;
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-linejoin: round;
    transition: transform 0.25s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .solar-hero__button:hover svg {
    transform: translateX(4px);
  }

  .solar-hero__note {
    margin: 14px 0 0;
    color: #aebdca;
    font-size: 13.5px;
  }

  .solar-hero__image-wrap {
    position: relative;
    isolation: isolate;
  }

  .solar-hero__image-wrap::before {
    content: "";
    position: absolute;
    inset: -16px;
    background: linear-gradient(135deg, rgba(255, 207, 77, 0.18), transparent 60%);
    border-radius: 36px;
    z-index: -1;
    filter: blur(20px);
  }

  .solar-hero__image {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 28px;
    display: block;
    box-shadow: 0 30px 70px rgba(0, 0, 0, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  .solar-hero__floating-card {
    position: absolute;
    left: 22px;
    bottom: 22px;
    background: rgba(2, 6, 10, 0.78);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 207, 77, 0.25);
    border-radius: 18px;
    padding: 14px 18px;
    display: grid;
    gap: 4px;
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.4);
    max-width: 220px;
  }

  .solar-hero__floating-card strong {
    color: #ffd46a;
    font-size: 15px;
    letter-spacing: 0.01em;
  }

  .solar-hero__floating-card span {
    color: #ffffff;
    font-size: 13px;
    opacity: 0.85;
  }

  @media (max-width: 820px) {
    .solar-hero {
      padding: 48px 16px;
    }

    .solar-hero__content {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    .solar-hero__text {
      text-align: center;
    }

    .solar-hero__subtitle {
      margin-left: auto;
      margin-right: auto;
    }

    .solar-hero__benefits {
      text-align: left;
      background: rgba(255, 255, 255, 0.06);
      padding: 18px;
      border-radius: 18px;
      border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .solar-hero__button {
      width: 100%;
      max-width: 360px;
    }

    .solar-hero__floating-card {
      left: 14px;
      bottom: 14px;
      padding: 12px 14px;
    }
  }
{%- endstyle -%}

<section class="solar-hero" id="solar-hero-{{ section.id }}">
  <div class="solar-hero__content">
    <div class="solar-hero__text">
      {%- if section.settings.badge != blank -%}
        <span class="solar-hero__badge">{{ section.settings.badge | escape }}</span>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1>{{ section.settings.heading | escape }}</h1>
      {%- endif -%}

      {%- if section.settings.subtitle != blank -%}
        <p class="solar-hero__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div class="solar-hero__benefits">
          {%- for block in section.blocks -%}
            {%- if block.type == 'benefit' -%}
              <div {{ block.shopify_attributes }}>
                <span class="check" aria-hidden="true">
                  <svg viewBox="0 0 24 24"><path d="M5 12l4 4 10-10"/></svg>
                </span>
                <span>{{ block.settings.text | escape }}</span>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <a
          href="{{ section.settings.button_link | default: '#comprar' }}"
          class="solar-hero__button"
          data-solar-hero-cta
        >
          {{ section.settings.button_label | escape }}
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M5 12h14"/>
            <path d="M13 6l6 6-6 6"/>
          </svg>
        </a>
      {%- endif -%}

      {%- if section.settings.note != blank -%}
        <p class="solar-hero__note">{{ section.settings.note | escape }}</p>
      {%- endif -%}
    </div>

    <div class="solar-hero__image-wrap">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'eager', class: 'solar-hero__image', alt: section.settings.heading }}
      {%- elsif product.featured_media != blank -%}
        <img
          src="{{ product.featured_media | image_url: width: 1200 }}"
          alt="{{ product.featured_media.alt | default: section.settings.heading | escape }}"
          class="solar-hero__image"
          width="{{ product.featured_media.width }}"
          height="{{ product.featured_media.height }}"
          loading="eager"
        >
      {%- else -%}
        <img
          src="{{ 'lampara-solar-1.jpg' | asset_url }}"
          alt="{{ section.settings.heading | escape }}"
          class="solar-hero__image"
          loading="eager"
        >
      {%- endif -%}

      {%- if section.settings.floating_title != blank or section.settings.floating_subtitle != blank -%}
        <div class="solar-hero__floating-card">
          {%- if section.settings.floating_title != blank -%}
            <strong>{{ section.settings.floating_title | escape }}</strong>
          {%- endif -%}
          {%- if section.settings.floating_subtitle != blank -%}
            <span>{{ section.settings.floating_subtitle | escape }}</span>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<script>
  (function () {
    var btn = document.querySelector('#solar-hero-{{ section.id }} [data-solar-hero-cta]');
    if (!btn) return;
    btn.addEventListener('click', function (e) {
      var href = btn.getAttribute('href') || '';
      if (href === '#comprar' || href === '') {
        e.preventDefault();
        var target = document.getElementById('comprar')
          || document.querySelector('product-form')
          || document.querySelector('form[action*="/cart/add"]')
          || document.querySelector('[name="add"]');
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Hero Lámpara",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "badge",
      "label": "Etiqueta superior",
      "default": "Lámpara Solar de Pared · 4 Focos LED"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Título",
      "default": "Ilumina y protege tu hogar automáticamente con energía solar"
    },
    {
      "type": "richtext",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "<p>La Lámpara Solar de Pared de 4 Focos se carga con el sol durante el día y enciende su luz al detectar movimiento, ideal para entradas, patios, jardines, garajes y fachadas.</p>"
    },
    {
      "type": "header",
      "content": "Botón de compra"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texto del botón",
      "default": "Comprar ahora"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Enlace del botón (deja en #comprar para hacer scroll al carrito)"
    },
    {
      "type": "text",
      "id": "note",
      "label": "Nota debajo del botón",
      "default": "Ahorra energía y mejora la seguridad de tus espacios exteriores."
    },
    {
      "type": "header",
      "content": "Imagen y tarjeta flotante"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen del hero (opcional, usa la del producto si está vacío)"
    },
    {
      "type": "text",
      "id": "floating_title",
      "label": "Tarjeta flotante - Título",
      "default": "Encendido automático"
    },
    {
      "type": "text",
      "id": "floating_subtitle",
      "label": "Tarjeta flotante - Subtítulo",
      "default": "Ideal para exteriores"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Beneficio",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Texto",
          "default": "Beneficio del producto"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Hero Lámpara",
      "blocks": [
        { "type": "benefit", "settings": { "text": "4 focos LED de alta visibilidad" } },
        { "type": "benefit", "settings": { "text": "Sensor de movimiento integrado" } },
        { "type": "benefit", "settings": { "text": "Funciona con energía solar" } },
        { "type": "benefit", "settings": { "text": "Resistente a lluvia y clima exterior" } }
      ]
    }
  ]
}
{% endschema %}
